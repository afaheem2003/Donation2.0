generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Auth (NextAuth adapter tables) ──────────────────────────────────────────

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ─── Core models ─────────────────────────────────────────────────────────────

enum UserRole {
  DONOR
  NONPROFIT_ADMIN
  PLATFORM_ADMIN
}

model User {
  id        String   @id @default(cuid())
  name      String?
  email     String   @unique
  username  String   @unique @default(cuid())
  avatarUrl String?
  role      UserRole @default(DONOR)
  createdAt DateTime @default(now())

  // NextAuth
  emailVerified DateTime?
  accounts      Account[]
  sessions      Session[]

  // App relations
  nonprofitAdmins NonprofitAdmin[]
  donations       Donation[]
  posts           Post[]
  likes           Like[]
  comments        Comment[]
  following       Follow[]         @relation("follower")
  followers       Follow[]         @relation("following")
}

enum NonprofitCategory {
  EDUCATION
  HEALTH
  ENVIRONMENT
  ARTS
  HUMAN_SERVICES
  ANIMALS
  INTERNATIONAL
  RELIGION
  COMMUNITY
  OTHER
}

model Nonprofit {
  id          String            @id @default(cuid())
  name        String
  ein         String            @unique
  description String            @db.Text
  category    NonprofitCategory @default(OTHER)
  website     String?
  logoUrl     String?
  verified    Boolean           @default(false)
  createdAt   DateTime          @default(now())

  admins    NonprofitAdmin[]
  donations Donation[]
  posts     Post[]
}

enum AdminRole {
  OWNER
  ADMIN
}

model NonprofitAdmin {
  id          String    @id @default(cuid())
  userId      String
  nonprofitId String
  role        AdminRole @default(ADMIN)
  createdAt   DateTime  @default(now())

  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  nonprofit Nonprofit @relation(fields: [nonprofitId], references: [id], onDelete: Cascade)

  @@unique([userId, nonprofitId])
}

enum DonationStatus {
  PENDING
  SUCCEEDED
  FAILED
  REFUNDED
}

model Donation {
  id                       String         @id @default(cuid())
  userId                   String
  nonprofitId              String
  amountCents              Int
  currency                 String         @default("usd")
  status                   DonationStatus @default(PENDING)
  stripeCheckoutSessionId  String?        @unique
  stripePaymentIntentId    String?
  donatedAt                DateTime?
  createdAt                DateTime       @default(now())

  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  nonprofit Nonprofit @relation(fields: [nonprofitId], references: [id], onDelete: Cascade)
  receipt   Receipt?
  posts     Post[]
}

model Receipt {
  id            String   @id @default(cuid())
  donationId    String   @unique
  receiptNumber String   @unique
  pdfUrl        String?
  issuedAt      DateTime @default(now())
  taxYear       Int
  legalText     String   @db.Text

  donation Donation @relation(fields: [donationId], references: [id], onDelete: Cascade)
}

model Post {
  id          String   @id @default(cuid())
  userId      String
  nonprofitId String
  donationId  String?
  caption     String   @db.Text
  imageUrl    String?
  isDeleted   Boolean  @default(false)
  createdAt   DateTime @default(now())

  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  nonprofit Nonprofit @relation(fields: [nonprofitId], references: [id], onDelete: Cascade)
  donation  Donation? @relation(fields: [donationId], references: [id], onDelete: SetNull)
  likes     Like[]
  comments  Comment[]
}

model Like {
  id        String   @id @default(cuid())
  postId    String
  userId    String
  createdAt DateTime @default(now())

  post Post @relation(fields: [postId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([postId, userId])
}

model Comment {
  id        String   @id @default(cuid())
  postId    String
  userId    String
  body      String   @db.Text
  createdAt DateTime @default(now())

  post Post @relation(fields: [postId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Follow {
  id          String   @id @default(cuid())
  followerId  String
  followingId String
  createdAt   DateTime @default(now())

  follower  User @relation("follower", fields: [followerId], references: [id], onDelete: Cascade)
  following User @relation("following", fields: [followingId], references: [id], onDelete: Cascade)

  @@unique([followerId, followingId])
}
